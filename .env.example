# Root environment template for local development.
# Copy values into local environment files only. Do not commit real secrets.

# Web app: web/.env.local
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# Flutter app: pass via --dart-define
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Supabase Edge Functions secrets
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
OPENAI_API_KEY=YOUR_OPTIONAL_PROVIDER_KEY
ANTHROPIC_API_KEY=YOUR_OPTIONAL_PROVIDER_KEY
GEMINI_API_KEY=YOUR_OPTIONAL_PROVIDER_KEY
REVENUECAT_SECRET_KEY=YOUR_OPTIONAL_REVENUECAT_SECRET
FCM_SERVER_KEY=YOUR_OPTIONAL_FCM_SECRET
EMAIL_PROVIDER_API_KEY=YOUR_OPTIONAL_EMAIL_SECRET
